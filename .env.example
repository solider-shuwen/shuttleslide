# Shuttleslide configuration.
#
# Copy this file to `.env` (same directory) and fill in real values.
# `slidecraft review` auto-loads `.env` on startup via python-dotenv;
# `slidecraft generate` reads the same variables via AgentConfig.from_env.
#
# Precedence (highest wins):
#   1. CLI flags on `slidecraft review` (--api-base, --model, ...)
#   2. Values in this .env file
#   3. Hardcoded defaults in AgentConfig
#
# In `slidecraft review`, any field set here (or via CLI) LOCKS the
# corresponding field in the web form — the input becomes read-only.
# When API_BASE + API_KEY + MODEL are all set, the credentials section
# of the form hides entirely and only the model name is shown.

# ---------------------------------------------------------------------------
# Required — text LLM endpoint
# ---------------------------------------------------------------------------
SHUTTLESLIDE_API_BASE=https://api.deepseek.com
SHUTTLESLIDE_API_KEY=sk-your-key-here
SHUTTLESLIDE_MODEL=deepseek-v4-flash

# ---------------------------------------------------------------------------
# Optional — Vision LLM endpoint (for image verification)
# ---------------------------------------------------------------------------
# Set these when the vision model lives on a different endpoint from the
# text LLM (typical: text on DeepSeek, vision on Zhipu GLM-4V). When
# unset, the orchestrator falls back to the text LLM endpoint above.
# SHUTTLESLIDE_VLM_API_BASE=https://open.bigmodel.cn/api/paas/v4
# SHUTTLESLIDE_VLM_API_KEY=sk-your-vlm-key-here
# SHUTTLESLIDE_VLM_MODEL=glm-4v

# ---------------------------------------------------------------------------
# Optional — Web image acquisition
# ---------------------------------------------------------------------------
# Provider for slide hero/background images. Currently supported:
#   bing_web  — Bing image search (requires API key)
#   stub      — offline placeholder images, no network
# Leave unset for an SVG-only deck.
# SHUTTLESLIDE_IMAGE_SEARCH_PROVIDER=bing_web
# SHUTTLESLIDE_IMAGE_SEARCH_BASE_URL=https://cn.bing.com

# ---------------------------------------------------------------------------
# Optional — Pipeline behavior flags
# ---------------------------------------------------------------------------
# Disable required tool choice (some providers don't support it).
# Set to true when using DeepSeek models — they reject
# tool_choice="required" with HTTP 400 in thinking mode; the client
# silently rewrites "required" → "auto" when this is on.
# Default: false (allowed values: 1, true, yes, on).
# SHUTTLESLIDE_DISABLE_REQUIRED_TOOL_CHOICE=true

# Enable VLM verification of fetched images (slower, more accurate).
# Default: true. Auto-disabled when image_search_provider is unset.
# SHUTTLESLIDE_ENABLE_VLM_VERIFICATION=true